---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Jorge Armando Ceras Cárdenas - Web Developer and DJ"
  description="Hi there! I'm Jorge Armando Ceras Cárdenas, a Mexican Web Developer and DJ."
>
  <main
    class="w-full max-w-screen-lg mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 lg:py-16 xl:py-20"
  >
    <h1
      class="text-4xl sm:text-5xl lg:text-6xl font-bold text-center mb-8 sm:mb-12 lg:mb-16 xl:mb-20"
    >
      Jorge Armando Ceras Cárdenas
    </h1>
    <p
      class="text-lg sm:text-xl lg:text-2xl text-center mb-8 sm:mb-12 lg:mb-16 xl:mb-20"
    >
      Web Developer and DJ
    </p>
  </main>
</Layout>
